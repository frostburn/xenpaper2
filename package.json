{
  "name": "xenpaper2",
  "version": "2.0.0-beta.8",
  "description": "Xenpaper 2 is a text-based microtonal sequencer for writing musical ideas, playing them in the browser, and sharing them by URL or embed code.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run compile:grammar && vite",
    "build": "npm run compile:grammar && run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "npm run compile:grammar && vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "compile:grammar": "peggy --format es src/grammars/grammar.peggy -o src/grammars/grammar.generated.js"
  },
  "dependencies": {
    "aperiodic-oscillator": "^0.3.3",
    "peggy": "^5.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.1.0",
    "xen-dev-utils": "^0.15.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.19",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "oxlint": "~1.60.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "author": {
    "name": "Lumi Pakkanen"
  },
  "contributors": [
    {
      "name": "Damien Clarke",
      "url": "https://github.com/dxinteractive"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xenharmonic-devs/xenpaper2.git"
  },
  "bugs": {
    "url": "https://github.com/xenharmonic-devs/xenpaper2/issues"
  },
  "homepage": "https://github.com/xenharmonic-devs/xenpaper2#readme",
  "keywords": [
    "Microtonal",
    "Music",
    "Sequencer",
    "Xenharmonic",
    "Scales",
    "Frequency",
    "Equal Temperament",
    "DSL"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/frostburn"
  }
}
